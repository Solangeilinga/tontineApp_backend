// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANTS (Gérants) ─────────────────────────────────────────────────────
model Tenant {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  photoUrl   String?  @map("photo_url")
  pinHash    String?  @map("pin_hash")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  groups        Group[]
  users         User[]
  notifications Notification[]

  @@map("tenants")
}

// ─── USERS (Membres des tontines) ──────────────────────────────────────────
model User {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  name       String
  phone      String
  photoUrl   String?  @map("photo_url")
  fcmToken   String?  @map("fcm_token")
  pinHash    String?  @map("pin_hash")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  groupMembers  GroupMember[]
  contributions Contribution[]
  turns         Turn[]
  notifications Notification[]

  @@unique([tenantId, phone])
  @@map("users")
}

// ─── GROUPS (Groupes de tontine) ───────────────────────────────────────────
model Group {
  id             String           @id @default(uuid())
  tenantId       String           @map("tenant_id")
  name           String
  type           ContributionType
  frequencyValue Int              @default(1) @map("frequency_value")
  frequencyUnit  FrequencyUnit    @default(MONTHS) @map("frequency_unit")
  amount         Float
  currency       String           @default("XOF")
  description    String?
  inviteCode     String           @unique @map("invite_code")
  maxMembers     Int?             @map("max_members")
  isActive       Boolean          @default(true) @map("is_active")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  // Relations
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  groupMembers  GroupMember[]
  contributions Contribution[]
  turns         Turn[]
  cycles        Cycle[]

  @@map("groups")
}

// ─── GROUP_MEMBERS ─────────────────────────────────────────────────────────
model GroupMember {
  id        String   @id @default(uuid())
  groupId   String   @map("group_id")
  userId    String   @map("user_id")
  orderTurn Int      @map("order_turn")
  joinedAt  DateTime @default(now()) @map("joined_at")

  // Relations
  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@unique([groupId, orderTurn])
  @@map("group_members")
}

// ─── CYCLES (Tours de rotation complets) ──────────────────────────────────
// Un cycle = un tour de rotation complet du groupe : chaque membre reçoit
// sa mise une fois (dans l'ordre de orderTurn), selon un calendrier calculé
// à l'avance à partir de startDate + fréquence du groupe. Une fois tous les
// membres servis, le gérant clôture le cycle et un nouveau cycle démarre.
model Cycle {
  id          String      @id @default(uuid())
  groupId     String      @map("group_id")
  cycleNumber Int         @map("cycle_number")
  status      CycleStatus @default(ACTIVE)
  startDate   DateTime    @map("start_date")
  dueDate     DateTime?   @map("due_date")
  endDate     DateTime?   @map("end_date")
  createdAt   DateTime    @default(now()) @map("created_at")

  // Relations
  group         Group          @relation(fields: [groupId], references: [id])
  contributions Contribution[]
  turns         Turn[]

  @@unique([groupId, cycleNumber])
  @@map("cycles")
}

// ─── CONTRIBUTIONS ─────────────────────────────────────────────────────────
model Contribution {
  id          String             @id @default(uuid())
  groupId     String             @map("group_id")
  userId      String             @map("user_id")
  cycleId     String             @map("cycle_id")
  roundNumber Int                @map("round_number")
  status      ContributionStatus @default(PENDING)
  amount      Float
  dueDate     DateTime           @map("due_date")
  paidDate    DateTime?          @map("paid_date")
  note        String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  // Relations
  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  cycle Cycle @relation(fields: [cycleId], references: [id])

  @@map("contributions")
}

// ─── TURNS ─────────────────────────────────────────────────────────────────
model Turn {
  id            String     @id @default(uuid())
  groupId       String     @map("group_id")
  userId        String     @map("user_id")
  cycleId       String     @map("cycle_id")
  turnNumber    Int        @map("turn_number")
  scheduledDate DateTime   @map("scheduled_date")
  status        TurnStatus @default(UPCOMING)
  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  group Group @relation(fields: [groupId], references: [id])
  user  User  @relation(fields: [userId], references: [id])
  cycle Cycle @relation(fields: [cycleId], references: [id])

  @@unique([cycleId, turnNumber])
  @@map("turns")
}

// ─── NOTIFICATIONS ─────────────────────────────────────────────────────────
model Notification {
  id       String           @id @default(uuid())
  tenantId String           @map("tenant_id")
  userId   String           @map("user_id")
  type     NotificationType
  title    String
  message  String
  data     Json?
  isRead   Boolean          @default(false) @map("is_read")
  sentAt   DateTime         @default(now()) @map("sent_at")

  // Relations
  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ─── AUDIT LOG ─────────────────────────────────────────────────────────────
// Historique immuable des actions effectuées dans un groupe. Volontairement
// SANS relation de clé étrangère (autre que tenantId pour le scoping) afin
// que l'historique survive même si le groupe, l'utilisateur ou l'entité
// concernée est supprimé par la suite — un journal d'audit doit rester
// consultable indépendamment du cycle de vie des données qu'il décrit.
model AuditLog {
  id         String    @id @default(uuid())
  tenantId   String    @map("tenant_id")
  groupId    String?   @map("group_id")
  actorType  ActorType @map("actor_type")
  actorId    String    @map("actor_id")
  actorName  String    @map("actor_name")
  action     String
  targetType String?   @map("target_type")
  targetId   String?   @map("target_id")
  metadata   Json?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([tenantId, groupId])
  @@map("audit_logs")
}

// ─── ENUMS ─────────────────────────────────────────────────────────────────
enum ContributionType {
  MONEY
  PHONE
  CLOTHES
  APPLIANCE
  OTHER
}

enum FrequencyUnit {
  DAYS
  WEEKS
  MONTHS
}

enum ContributionStatus {
  PENDING
  RECEIVED
  LATE
}

enum TurnStatus {
  UPCOMING
  CURRENT
  DONE
}

enum CycleStatus {
  ACTIVE
  COMPLETED
}

enum ActorType {
  TENANT
  USER
}

enum NotificationType {
  REMINDER_J2
  REMINDER_J1
  YOUR_TURN
  CONTRIBUTION_CONFIRMED
  CONTRIBUTION_OVERDUE
  TURN_OVERDUE
  MEMBER_JOINED
  GENERAL
}